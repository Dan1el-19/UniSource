{
  "name": "@unisource/sdk",
  "private": false,
  "type": "module",
  "version": "1.1.0",
  "description": "Wspolne kontrakty danych dla backendu i frontendu UniSource.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dan1el-19/UniSource.git",
    "directory": "packages/unisource-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./v2": {
      "types": "./dist/v2/index.d.mts",
      "import": "./dist/v2/index.mjs",
      "default": "./dist/v2/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "pnpm run build && vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260524.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
