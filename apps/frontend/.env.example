# SvelteKit public environment variables (copy to .env.local and fill in values)
# PUBLIC_ prefix makes variables available in browser code via $env/static/public

# Base URL of the UniSource backend API
PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Appwrite endpoint and project used for the Appwrite upload path
PUBLIC_APPWRITE_ENDPOINT=https://appwrite.example.com/v1
PUBLIC_APPWRITE_PROJECT_ID=
