# URL backendu (bez trailing slash)
API_BASE=https://api.usrc.dev

# Cloudflare Access — skopiuj z dashboardu Access > Applications > your app > Overview
CF_ACCESS_AUD=your-audience-tag-here
CF_ACCESS_TEAM=yourteam.cloudflareaccess.com

# Tylko lokalnie — pomija weryfikację JWT (nigdy nie ustawiaj na produkcji)
BYPASS_CF_ACCESS=true
