---
import UploadMvp from '../components/upload/UploadMvp.svelte';
import Layout from '../layouts/Layout.astro';
---

<Layout title="UniSource | Upload MVP">
	<main class="mx-auto w-full max-w-6xl px-4 py-8 md:px-8 md:py-14">
		<section class="mb-8 enter-fade md:mb-10">
			<p class="text-xs uppercase tracking-[0.25em] text-teal-800/75">UniSource Monorepo</p>
			<h1 class="mt-2 max-w-3xl text-4xl font-semibold leading-tight text-slate-900 md:text-5xl">
				Typowany most pomiedzy frontendem, backendem i SDK
			</h1>
			<p class="mt-4 max-w-3xl text-sm text-slate-700 md:text-base">
				Ta strona testuje koncowe flow uploadu plikow dla R2 i Appwrite, z pelna walidacja
				kontraktow na obu warstwach oraz obsluga bledow bez crashy UI.
			</p>
		</section>

		<UploadMvp client:load />
	</main>
</Layout>
