{
  "name": "backend",
  "private": true,
  "version": "0.0.7",
  "type": "module",
  "scripts": {
    "prepare:sdk": "pnpm --filter @unisource/sdk build",
    "dev": "wrangler dev",
    "generate:wrangler": "node ../../scripts/generate-wrangler-config.mjs backend",
    "build": "wrangler deploy --dry-run --minify",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "pretypecheck": "pnpm run prepare:sdk",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit",
    "pretest": "pnpm run prepare:sdk",
    "test": "vitest run",
    "test:watch": "vitest",
    "precheck": "pnpm run prepare:sdk",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit && vitest run",
    "release": "semantic-release"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@unisource/sdk": "workspace:*",
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.8.0",
    "hono": "^4.12.18",
    "node-appwrite": "^24.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20260501.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "miniflare": "^4.20260526.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.95.0"
  },
  "license": "Apache-2.0"
}
