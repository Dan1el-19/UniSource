{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "app-backend",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-11",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": false,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	},
	"build": {
		"command": "pnpm --filter @unisource/sdk build",
		"cwd": "../..",
		"watch_dir": ["src", "../../packages/unisource-sdk/src"]
	},
	"d1_databases": [
		{
			"binding": "APP_DB",
			"database_name": "app-db",
			"database_id": "00000000-0000-0000-0000-000000000000",
			"migrations_dir": "src/db/migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "PRIMARY_BUCKET",
			"bucket_name": "storage-primary-placeholder"
		},
		{
			"binding": "SECONDARY_BUCKET",
			"bucket_name": "storage-secondary-placeholder"
		}
	],
	"vars": {
		"R2_BUCKET_BINDINGS": "{\"primary\":\"PRIMARY_BUCKET\",\"secondary\":\"SECONDARY_BUCKET\"}",
		"R2_BUCKET_NAMES": "{\"primary\":\"storage-primary-placeholder\",\"secondary\":\"storage-secondary-placeholder\"}",
		"R2_ACCESS_KEY_ID": "test-access-key-id",
		"R2_SECRET_ACCESS_KEY": "test-secret-access-key-test-secret-access-key",
		"R2_ACCOUNT_ID": "test-account-id",
		"APPWRITE_ENDPOINT": "https://appwrite.test/v1",
		"APPWRITE_PROJECT_ID": "test-project-id",
		"APPWRITE_BUCKET_ID": "test-bucket-id",
		"APPWRITE_API_KEY": "test-appwrite-api-key",
		"CURSOR_HMAC_SECRET": "dGVzdC1zZWNyZXQtZm9yLWN1cnNvci1zaWduaW5nLWZvci12aXRlc3Q=",
		"ALLOWED_ORIGINS": "http://localhost:5173",
			"BYPASS_CF_ACCESS": "true"
	},
	"ratelimits": [
		{
			"name": "RL_GENERAL",
			"namespace_id": "1001",
			"simple": { "limit": 1000, "period": 60 }
		},
		{
			"name": "RL_UPLOAD_INIT",
			"namespace_id": "1002",
			"simple": { "limit": 30, "period": 60 }
		},
		{
			"name": "RL_PUBLIC_READ",
			"namespace_id": "1003",
			"simple": { "limit": 300, "period": 60 }
		},
		{
			"name": "RL_AUTH_FAIL",
			"namespace_id": "1004",
			"simple": { "limit": 10, "period": 60 }
		},
		{
			"name": "RL_SHARE_PASSWORD",
			"namespace_id": "1005",
			"simple": { "limit": 5, "period": 60 }
		}
	]
}
