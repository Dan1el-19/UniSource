{
  "name": "unisource",
  "private": true,
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status --verbose",
    "backend": "pnpm --filter ./apps/backend run dev",
    "frontend": "pnpm --filter ./apps/frontend dev",
    "release:sdk": "pnpm run changeset:version && pnpm --filter @unisource/sdk build && pnpm run changeset:publish",
    "sdk:deps:workspace": "node scripts/set-app-sdk-source.mjs workspace",
    "sdk:deps:npm": "node scripts/set-app-sdk-source.mjs npm"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.33.0"
}